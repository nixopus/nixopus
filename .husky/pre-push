echo "Building API..."
cd api
if ! go build -o /tmp/nixopus-api-test .; then
  echo "ERROR: API build failed"
  exit 1
fi
rm -f /tmp/nixopus-api-test
cd ..

echo "Building view..."
cd view
if [ -f yarn.lock ] || [ -f package-lock.json ]; then
  if ! (yarn build 2>/dev/null || npm run build 2>/dev/null); then
    echo "ERROR: View build failed"
    exit 1
  fi
else
  echo "WARNING: No package manager lockfile found in view directory"
fi
cd ..

echo "Build verification passed"
