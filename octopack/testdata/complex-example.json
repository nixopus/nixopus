{
  "directives": {
    "syntax": "docker/dockerfile:1",
    "escape": "\\",
    "check": {
      "skip": ["JSONArgsRecommended", "EmptyContinuationLine", "DuplicateStageName"],
      "error": false
    }
  },
  "global_args": [
    {
      "name": "VERSION",
      "default_value": "latest"
    },
    {
      "name": "BUILDPLATFORM",
      "default_value": "linux/amd64"
    },
    {
      "name": "TARGETPLATFORM",
      "default_value": "linux/amd64"
    }
  ],
  "stages": [
    {
      "from": {
        "image": "golang",
        "tag": "1.21-alpine",
        "as": "builder",
        "platform": "linux/amd64"
      },
      "instructions": [
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "arg",
          "name": "GO_VERSION",
          "default_value": "1.21"
        },
        {
          "type": "arg",
          "name": "CGO_ENABLED",
          "default_value": "0"
        },
        {
          "type": "env",
          "variables": {
            "CGO_ENABLED": "0",
            "GOOS": "linux",
            "GOARCH": "amd64",
            "GO111MODULE": "on",
            "GOPROXY": "https://proxy.golang.org,direct"
          }
        },
        {
          "type": "copy",
          "sources": ["go.mod", "go.sum"],
          "destination": "./",
          "chmod": "0644"
        },
        {
          "type": "run",
          "command": "go mod download",
          "mount": [
            {
              "type": "cache",
              "target": "/go/pkg/mod",
              "id": "gomod",
              "sharing": "shared"
            }
          ],
          "network": "default"
        },
        {
          "type": "copy",
          "sources": ["."],
          "destination": "./",
          "exclude": [".git", "node_modules", ".dockerignore", "*.md"]
        },
        {
          "type": "run",
          "command": ["go", "build", "-ldflags", "-s -w", "-o", "/app/main", "./cmd/server"],
          "mount": [
            {
              "type": "cache",
              "target": "/root/.cache/go-build",
              "id": "gobuild",
              "sharing": "shared",
              "uid": 1000,
              "gid": 1000
            }
          ],
          "network": "default",
          "security": "sandbox"
        },
        {
          "type": "run",
          "command": ["go", "test", "-v", "./..."],
          "network": "default"
        }
      ]
    },
    {
      "from": {
        "image": "node",
        "tag": "20-alpine",
        "as": "frontend-builder"
      },
      "instructions": [
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "copy",
          "sources": ["package.json", "package-lock.json", "tsconfig.json"],
          "destination": "./"
        },
        {
          "type": "run",
          "command": "npm ci --only=production",
          "mount": [
            {
              "type": "cache",
              "target": "/root/.npm",
              "id": "npm",
              "sharing": "shared"
            }
          ],
          "network": "default"
        },
        {
          "type": "copy",
          "sources": ["src", "public", "assets"],
          "destination": "./"
        },
        {
          "type": "run",
          "command": ["npm", "run", "build"],
          "network": "default"
        }
      ]
    },
    {
      "from": {
        "image": "alpine",
        "tag": "3.19",
        "platform": "linux/amd64"
      },
      "instructions": [
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "run",
          "command": "apk add --no-cache ca-certificates tzdata curl wget",
          "network": "default"
        },
        {
          "type": "copy",
          "from": "builder",
          "sources": ["/app/main"],
          "destination": "./main",
          "chmod": "0755",
          "chown": "1000:1000"
        },
        {
          "type": "copy",
          "from": "frontend-builder",
          "sources": ["/app/dist"],
          "destination": "/app/static",
          "chown": "1000:1000"
        },
        {
          "type": "user",
          "user": "1000",
          "group": "1000"
        },
        {
          "type": "expose",
          "ports": [
            {
              "port": 8080,
              "protocol": "tcp"
            },
            {
              "port": 9090,
              "protocol": "tcp"
            },
            {
              "port": 8443,
              "protocol": "tcp"
            }
          ]
        },
        {
          "type": "volume",
          "paths": ["/app/data", "/app/logs", "/app/config"]
        },
        {
          "type": "label",
          "labels": {
            "maintainer": "octopack@example.com",
            "version": "1.0.0",
            "description": "Complex multi-stage application",
            "org.opencontainers.image.title": "Complex App",
            "org.opencontainers.image.description": "A complex application built with Go and Node.js",
            "org.opencontainers.image.version": "1.0.0"
          }
        },
        {
          "type": "healthcheck",
          "command": ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:8080/health"],
          "interval": "30s",
          "timeout": "10s",
          "start_period": "40s",
          "start_interval": "10s",
          "retries": 3
        },
        {
          "type": "stopsignal",
          "signal": "SIGTERM"
        },
        {
          "type": "entrypoint",
          "command": ["./main"]
        },
        {
          "type": "cmd",
          "command": ["--config", "/app/config.yaml", "--log-level", "info"],
          "is_default_args": true
        }
      ]
    },
    {
      "from": {
        "image": "nginx",
        "tag": "alpine",
        "as": "nginx-stage"
      },
      "instructions": [
        {
          "type": "copy",
          "from": "frontend-builder",
          "sources": ["/app/dist"],
          "destination": "/usr/share/nginx/html",
          "chown": "nginx:nginx"
        },
        {
          "type": "copy",
          "sources": ["nginx.conf", "nginx-default.conf"],
          "destination": "/etc/nginx/",
          "chmod": "0644",
          "chown": "root:root"
        },
        {
          "type": "run",
          "command": "nginx -t",
          "network": "none"
        },
        {
          "type": "expose",
          "ports": [
            {
              "port": 80,
              "protocol": "tcp"
            },
            {
              "port": 443,
              "protocol": "tcp"
            }
          ]
        },
        {
          "type": "onbuild",
          "instruction": {
            "type": "copy",
            "sources": ["custom-config.conf"],
            "destination": "/etc/nginx/conf.d/"
          }
        },
        {
          "type": "onbuild",
          "instruction": {
            "type": "run",
            "command": "chmod 644 /etc/nginx/conf.d/custom-config.conf"
          }
        },
        {
          "type": "cmd",
          "command": ["nginx", "-g", "daemon off;"]
        }
      ]
    },
    {
      "from": {
        "image": "ubuntu",
        "tag": "22.04"
      },
      "instructions": [
        {
          "type": "shell",
          "shell": ["/bin/bash", "-c"]
        },
        {
          "type": "run",
          "command": "apt-get update && apt-get install -y curl wget git build-essential",
          "network": "default",
          "security": "sandbox"
        },
        {
          "type": "run",
          "command": ["sh", "-c", "echo 'Complex exec form with shell' && echo 'Multiple commands'"],
          "mount": [
            {
              "type": "bind",
              "target": "/mnt/data",
              "source": "/host/data",
              "from": "builder",
              "readonly": true
            },
            {
              "type": "secret",
              "target": "/run/secrets/api-key",
              "id": "api-key",
              "mode": "0600",
              "required": true
            },
            {
              "type": "secret",
              "target": "/run/secrets/db-password",
              "id": "db-password",
              "mode": "0400",
              "required": true
            },
            {
              "type": "ssh",
              "target": "/root/.ssh",
              "id": "default",
              "mode": "0600",
              "required": false
            },
            {
              "type": "cache",
              "target": "/var/cache/apt",
              "id": "apt-cache",
              "sharing": "private",
              "uid": 0,
              "gid": 0
            },
            {
              "type": "tmpfs",
              "target": "/tmp",
              "uid": 1000,
              "gid": 1000
            }
          ],
          "network": "host",
          "security": "insecure"
        },
        {
          "type": "add",
          "sources": ["https://example.com/file.tar.gz"],
          "destination": "/tmp/",
          "checksum": "sha256:abc123def456...",
          "unpack": true,
          "chown": "root:root",
          "chmod": "0644"
        },
        {
          "type": "add",
          "sources": ["https://github.com/user/repo.git"],
          "destination": "/app/repo",
          "keep_git_dir": true
        },
        {
          "type": "maintainer",
          "name": "Complex Example Maintainer <maintainer@example.com>"
        },
        {
          "type": "label",
          "labels": {
            "com.example.vendor": "Example Corp",
            "com.example.license": "MIT",
            "com.example.version": "2.0.0"
          }
        }
      ]
    },
    {
      "from": {
        "image": "python",
        "tag": "3.11-slim",
        "as": "python-builder"
      },
      "instructions": [
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "env",
          "variables": {
            "PYTHONUNBUFFERED": "1",
            "PYTHONDONTWRITEBYTECODE": "1",
            "PIP_NO_CACHE_DIR": "1",
            "PIP_DISABLE_PIP_VERSION_CHECK": "1"
          }
        },
        {
          "type": "run",
          "command": "pip install --no-cache-dir -r requirements.txt",
          "mount": [
            {
              "type": "cache",
              "target": "/root/.cache/pip",
              "id": "pip-cache",
              "sharing": "shared"
            }
          ]
        },
        {
          "type": "copy",
          "sources": ["app.py", "requirements.txt"],
          "destination": "./"
        },
        {
          "type": "run",
          "command": ["python", "-m", "pytest", "tests/"]
        }
      ]
    },
    {
      "from": {
        "image": "python",
        "tag": "3.11-alpine"
      },
      "instructions": [
        {
          "type": "copy",
          "from": "python-builder",
          "sources": ["/app"],
          "destination": "/app",
          "link": true,
          "parents": true
        },
        {
          "type": "workdir",
          "path": "/app"
        },
        {
          "type": "user",
          "user": "python",
          "group": "python"
        },
        {
          "type": "expose",
          "ports": [
            {
              "port": 5000,
              "protocol": "tcp"
            }
          ]
        },
        {
          "type": "healthcheck",
          "none": false,
          "command": ["CMD", "python", "-c", "import requests; requests.get('http://localhost:5000/health')"],
          "interval": "30s",
          "timeout": "5s",
          "start_period": "30s",
          "retries": 5
        },
        {
          "type": "entrypoint",
          "command": ["python"]
        },
        {
          "type": "cmd",
          "command": ["app.py"]
        }
      ]
    }
  ]
}

